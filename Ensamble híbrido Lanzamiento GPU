# Modelo de respaldo MLP simple de PyTorch (usado si Qiskit no está disponible)
class SimpleMLP(nn.Module):
    def __init__(self, input_dim, n_classes, hidden=[64,32]):
        super().__init__()
        layers = []
        prev = input_dim
        for h in hidden:
            layers.append(nn.Linear(prev, h)); layers.append(nn.ReLU()); layers.append(nn.Dropout(0.2))
            prev = h
        layers.append(nn.Linear(prev, n_classes))
        self.net = nn.Sequential(*layers)
    def forward(self, x): return self.net(x)

def build_qnn_circuit_and_qnn(feature_map_name, ansatz_type, feature_dim, backend, use_ibm_runtime=False):
    if not HAS_QISKIT:
        raise RuntimeError("Qiskit no está disponible para redes neuronales cuánticas.")
    feature_map = build_feature_map(feature_map_name, feature_dim, reps=1)
    if ansatz_type == "efficientsu2":
        ansatz = EfficientSU2(num_qubits=feature_dim, reps=2, entanglement='full')
    else:
        ansatz = EfficientSU2(num_qubits=feature_dim, reps=1, entanglement='full')

    x_params = ParameterVector("x", len(feature_map.parameters))
    w_params = ParameterVector("w", len(ansatz.parameters))
    fm = feature_map.assign_parameters({p: x_params[i] for i, p in enumerate(feature_map.parameters)})
    an = ansatz.assign_parameters({p: w_params[i] for i, p in enumerate(ansatz.parameters)})

    qc = QuantumCircuit(feature_dim)
    qc.compose(fm, inplace=True)
    qc.compose(an, inplace=True)

    qnn = EstimatorQNN(circuit=qc, input_params=x_params, weight_params=w_params,
                       estimator=backend["runtime_estimator"] if use_ibm_runtime else Estimator())
    return qnn, feature_map, ansatz

# Definición del modelo híbrido (VQC + capa clásica)
class HybridVQC(nn.Module):
    def __init__(self, qnn, n_classes):
        super().__init__()
        self.qnn = TorchConnector(qnn)
        self.classifier = nn.Sequential(
            nn.Linear(1, 128),
            nn.ReLU(),
            nn.Dropout(0.1),
            nn.Linear(128, n_classes)
        )
    def forward(self, x):
        out = self.qnn(x)
        if out.dim() == 1:
            out = out.unsqueeze(1)
        return self.classifier(out)

@trace
def train_vqc(X_train, y_train, n_classes,
              feature_map_name="pauli",
              reps_feature=1, reps_ansatz=1,
              batch_size=8, max_epochs=10, patience=5,
              lr=3e-4, backend=None, use_ibm_runtime=False, device="cpu", fallback_seed: int = GLOBAL_SEED):
    if torch is not None:
        torch.manual_seed(fallback_seed)
        torch.use_deterministic_algorithms(False)

    if (not HAS_QISKIT) or (torch is None) or (backend is None):
        logger.warning("Ruta cuántica VQC no disponible -> usando alternativa clásica MLP.")
        mlp = SimpleMLP(input_dim=X_train.shape[1], n_classes=n_classes, hidden=[64,32])
        device = torch.device(device) if torch is not None else "cpu"
        if torch is None:
            clf = MLPClassifier(hidden_layer_sizes=(64,32), max_iter=200, random_state=fallback_seed)
            clf.fit(X_train, y_train)
            return clf, {"fallback": True, "type": "sklearn_mlp"}
        mlp.to(device)
        opt = optim.AdamW(mlp.parameters(), lr=lr)
        crit = nn.CrossEntropyLoss()
        loader = DataLoader(TensorDataset(torch.tensor(X_train,dtype=torch.float32),
                                          torch.tensor(y_train,dtype=torch.long)),
                            batch_size=batch_size, shuffle=True)
        best_loss, wait = float("inf"), 0
        for epoch in range(max_epochs):
            mlp.train(); total_loss = 0.
            for xb, yb in loader:
                xb, yb = xb.to(device), yb.to(device)
                opt.zero_grad(); logits = mlp(xb); loss = crit(logits, yb)
                loss.backward(); opt.step(); total_loss += loss.item()
            if total_loss < best_loss - 1e-4:
                best_loss, wait = total_loss, 0
            else:
                wait += 1
                if wait >= patience:
                    break
        return mlp, {"fallback": True, "type": "torch_mlp"}

    try:
        qnn, fmap, ansatz = build_qnn_circuit_and_qnn(feature_map_name, "efficientsu2", X_train.shape[1], backend, use_ibm_runtime)
        hybrid = HybridVQC(qnn, n_classes)
        device = torch.device(device)
        hybrid.to(device)
        opt = optim.AdamW(hybrid.parameters(), lr=lr, weight_decay=1e-4)
        crit = nn.CrossEntropyLoss()
        loader = DataLoader(TensorDataset(torch.tensor(X_train,dtype=torch.float32), torch.tensor(y_train,dtype=torch.long)),
                            batch_size=batch_size, shuffle=True)
        best_loss, wait = float("inf"), 0
        for epoch in range(max_epochs):
            hybrid.train(); total_loss = 0.
            for xb, yb in loader:
                xb, yb = xb.to(device), yb.to(device)
                opt.zero_grad(); logits = hybrid(xb); loss = crit(logits, yb)
                loss.backward(); opt.step(); total_loss += loss.item()
            if total_loss < best_loss - 1e-4:
                best_loss, wait = total_loss, 0
                torch.save(hybrid.state_dict(), "mejor_vqc_híbrido.pth")
            else:
                wait += 1
                if wait >= patience:
                    break
        return hybrid, {
            "fallback": False,
            "qnn": "EstimatorQNN",
            "fmap": str(type(fmap).__name__),
            "ansatz": str(type(ansatz).__name__)
        }
    except Exception as e:
        logger.exception("El entrenamiento cuántico VQC falló, recurriendo a MLP clásico: %s", e)
        clf = MLPClassifier(hidden_layer_sizes=(64,32), max_iter=200, random_state=fallback_seed)
        clf.fit(X_train, y_train)
        return clf, {"fallback": True, "type": "sklearn_mlp"}


@trace
def train_qcnn_like(X_train, y_train, n_classes, backend, use_ibm_runtime=False,
                    batch_size=8, max_epochs=10, patience=5, device="cpu", fallback_seed: int = GLOBAL_SEED):
    if not HAS_QISKIT or backend is None:
        logger.warning("Ruta cuántica de QCNN no disponible -> usando clasificador de reserva clásico (RandomForest).")
        clf = RandomForestClassifier(n_estimators=200, random_state=fallback_seed)
        clf.fit(X_train, y_train)
        return clf, {"fallback": True, "type": "rf"}

    try:
        feature_dim = X_train.shape[1]

        feature_map = ZZFeatureMap(feature_dimension=feature_dim, reps=1, entanglement="linear")

        qc = QuantumCircuit(feature_dim)
        params = []

        for i in range(0, feature_dim-1, 2):
            theta1, theta2 = Parameter(f"\u03b8_{i}"), Parameter(f"\u03b8_{i+1}")
            qc.ry(theta1, i)
            qc.cx(i, i+1)
            qc.ry(theta2, i+1)
            params.extend([theta1, theta2])

        for i in range(feature_dim-1):
            qc.cz(i, i+1)

        x_params = ParameterVector("x", len(feature_map.parameters))
        w_params = ParameterVector("w", len(params))

        fm = feature_map.assign_parameters({p: x_params[i] for i, p in enumerate(feature_map.parameters)})
        an = qc.assign_parameters({p: w_params[i] for i, p in enumerate(params)})

        circuit = QuantumCircuit(feature_dim)
        circuit.compose(fm, inplace=True)
        circuit.compose(an, inplace=True)

        qnn = EstimatorQNN(
            circuit=circuit,
            input_params=x_params,
            weight_params=w_params,
            estimator=backend["runtime_estimator"] if use_ibm_runtime else Estimator()
        )

        class HybridQCNN(nn.Module):
            def __init__(self, qnn_module, n_classes):
                super().__init__()
                self.qnn = TorchConnector(qnn_module)
                self.classifier = nn.Sequential(
                    nn.Linear(1, 128),
                    nn.ReLU(),
                    nn.Dropout(0.1),
                    nn.Linear(128, n_classes)
                )
            def forward(self, x):
                out = self.qnn(x)
                if out.dim() == 1:
                    out = out.unsqueeze(1)
                return self.classifier(out)

        hybrid = HybridQCNN(qnn, n_classes)

        device = torch.device(device)
        hybrid.to(device)
        opt = optim.AdamW(hybrid.parameters(), lr=3e-4, weight_decay=1e-4)
        crit = nn.CrossEntropyLoss()
        loader = DataLoader(TensorDataset(torch.tensor(X_train, dtype=torch.float32),
                                          torch.tensor(y_train, dtype=torch.long)),
                            batch_size=batch_size, shuffle=True)

        best_loss, wait = float("inf"), 0
        for epoch in range(max_epochs):
            hybrid.train(); total_loss = 0.
            for xb, yb in loader:
                xb, yb = xb.to(device), yb.to(device)
                opt.zero_grad(); logits = hybrid(xb); loss = crit(logits, yb)
                loss.backward(); opt.step(); total_loss += loss.item()
            if total_loss < best_loss - 1e-4:
                best_loss, wait = total_loss, 0
                torch.save(hybrid.state_dict(), "mejor_qcnn_híbrido.pth")
            else:
                wait += 1
                if wait >= patience:
                    break

        return hybrid, {
            "fallback": False,
            "qnn": "EstimatorQNN",
            "fmap": str(type(feature_map).__name__),
            "ansatz": "QCNN-like"
        }

    except Exception as e:
        logger.exception("El entrenamiento de QCNN falló, volviendo a RandomForest: %s", e)
        clf = RandomForestClassifier(n_estimators=200, random_state=fallback_seed)
        clf.fit(X_train, y_train)
        return clf, {"fallback": True, "type": "rf"}


@trace
def train_xgboost(X_train, y_train, fallback_seed: int = GLOBAL_SEED):
    n_classes = len(np.unique(y_train))
    if n_classes > 2:
        clf = XGBClassifier(
            n_estimators=400, max_depth=7, learning_rate=0.05, subsample=0.8, colsample_bytree=0.8,
            objective='multi:softprob', num_class=n_classes,
            eval_metric='mlogloss',
            random_state=fallback_seed, use_label_encoder=False
        )
    else:
        clf = XGBClassifier(
            n_estimators=400, max_depth=7, learning_rate=0.05, subsample=0.8, colsample_bytree=0.8,
            objective='binary:logistic',
            eval_metric='logloss',
            random_state=fallback_seed, use_label_encoder=False
        )
    clf.fit(X_train, y_train)
    return clf


# -------------------------
# Utility: predictions, proba wrappers for sklearn/torch models - Utilidad: predicciones, envoltorios de probabilidad para modelos de sklearn/torch
# -------------------------
def predict_proba_model(model, X_np, batch=32, device="cpu") -> np.ndarray:
    try:
        if hasattr(model, "predict_proba"):
            return model.predict_proba(X_np)
    except Exception:
        pass

    if torch is not None and isinstance(model, torch.nn.Module):
        model.eval()
        ps = []
        with torch.no_grad():
            for i in range(0, X_np.shape[0], batch):
                xb = torch.tensor(X_np[i:i+batch], dtype=torch.float32).to(device)
                logits = model(xb)
                probs = torch.softmax(logits, dim=1).cpu().numpy()
                ps.append(probs)
        return np.vstack(ps)

    if hasattr(model, "decision_function"):
        scores = model.decision_function(X_np)
        if scores.ndim == 1:
            scores = np.vstack([-scores, scores]).T
        exp = np.exp(scores - np.max(scores, axis=1, keepdims=True))
        probs = exp / exp.sum(axis=1, keepdims=True)
        return probs

    preds = model.predict(X_np)
    n_classes = int(np.max(preds)) + 1
    proba = np.zeros((preds.shape[0], n_classes))
    proba[np.arange(preds.shape[0]), preds] = 1.0
    return proba


# -------------------------
# 6) Ensemble strategies - Ensamblado de estrategias
# -------------------------
def ensemble_predict_proba(models_probas: List[np.ndarray], strategy: str = "soft") -> np.ndarray:
    strategy = strategy.lower()
    stack = np.stack(models_probas, axis=0)
    if strategy == "soft":
        return np.mean(stack, axis=0)
    if strategy == "hard":
        preds = np.argmax(stack, axis=2)
        from scipy.stats import mode
        maj = mode(preds, axis=0, keepdims=False)[0].flatten()
        onehot = np.zeros((maj.size, stack.shape[2]))
        onehot[np.arange(maj.size), maj] = 1.0
        return onehot
    if strategy == "functional":
        soft = np.mean(stack, axis=0)
        preds = np.argmax(stack, axis=2)
        from scipy.stats import mode
        maj = mode(preds, axis=0, keepdims=False)[0].flatten()
        hard_onehot = np.zeros_like(soft)
        hard_onehot[np.arange(soft.shape[0]), maj] = 1.0
        return 0.7 * soft + 0.3 * hard_onehot
    raise ValueError("Estrategia de ensamblado desconocida")

# -------------------------
# 7) Evaluation & plots - Evaluación y gráficas
# -------------------------
def evaluate_model(y_true: np.ndarray, y_pred: np.ndarray, y_proba: np.ndarray,
                   model_name: str, label_names: List[str], out_dir: str = "./salidas") -> Dict:
    os.makedirs(out_dir, exist_ok=True)

    if not all(isinstance(c, str) for c in label_names):
        label_names = [str(c) for c in label_names]

    acc = accuracy_score(y_true, y_pred)
    prec = precision_score(y_true, y_pred, average="weighted", zero_division=0)
    rec = recall_score(y_true, y_pred, average="weighted", zero_division=0)
    f1 = f1_score(y_true, y_pred, average="weighted", zero_division=0)

    report = classification_report(y_true, y_pred,
                                   target_names=label_names,
                                   zero_division=0)
    logger.info("Reporte para %s:\n%s", model_name, report)

    cm = confusion_matrix(y_true, y_pred)
    plt.figure(figsize=(6, 5))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                xticklabels=label_names, yticklabels=label_names)
    plt.title(f"Matriz de confusión - {model_name}")
    plt.xlabel("Predicho")
    plt.ylabel("Verdadero")
    plt.tight_layout()
    plt.savefig(os.path.join(out_dir, f"{model_name}_confusion.png"))
    plt.close()

    try:
        if y_proba.shape[1] == 2:
            fpr, tpr, _ = roc_curve(y_true, y_proba[:, 1])
            roc_auc = auc(fpr, tpr)
        else:
            fpr, tpr, roc_auc = None, None, None
    except Exception:
        fpr, tpr, roc_auc = None, None, None

    return {
        "accuracy": acc,
        "precision": prec,
        "recall": rec,
        "f1": f1,
        "report": report,
        "confusion": cm,
        "proba": y_proba,
        "roc": (fpr, tpr, roc_auc)
    }

# -------------------------
# 8) Noise simulation & robustness curve - Simulación de ruido y curva de robustez
# -------------------------
def noise_robustness_curve(model_callable, X_test: np.ndarray, y_test: np.ndarray,
                           noise_levels: List[float] = None, repeats: int = 3, **predict_kwargs):
    if noise_levels is None:
        noise_levels = np.linspace(0.0, 0.5, 6)
    metrics = []
    for sigma in noise_levels:
        accs = []
        for r in range(repeats):
            X_noisy = X_test + np.random.normal(scale=sigma, size=X_test.shape)
            proba = predict_proba_model(model_callable, X_noisy, **predict_kwargs) if callable(model_callable) else predict_proba_model(model_callable, X_noisy, **predict_kwargs)
            preds = np.argmax(proba, axis=1)
            accs.append(accuracy_score(y_test, preds))
        metrics.append((sigma, np.mean(accs), np.std(accs)))
    return metrics

# -------------------------
# 9) CPU / Memory snapshot - Instantánea de memoria
# -------------------------
def snapshot_resource_usage():
    if not HAS_PSUTIL:
        return {"porcentaje_cpu": None, "porcentaje_de_memoria": None}
    return {"porcentaje_cpu": psutil.cpu_percent(interval=1.0), "porcentaje_de_memoria": psutil.virtual_memory().percent}

# -------------------------
# 10) Extras: calibration, grid weights, threshold tuning
# -------------------------

def calibrate_if_sklearn(clf, X_val, y_val):
    try:
        if hasattr(clf, "predict_proba"):
            # try isotonic first
            calib = CalibratedClassifierCV(base_estimator=clf, method='isotonic', cv='prefit')
            calib.fit(X_val, y_val)
            return calib
        else:
            return clf
    except Exception:
        try:
            calib = CalibratedClassifierCV(base_estimator=clf, method='isotonic', cv=3)
            calib.fit(X_val, y_val)
            return calib
        except Exception:
            return clf


def grid_search_ensemble_weights(prob_list_val: List[np.ndarray], y_val: np.ndarray, w_range=range(1,5)) -> np.ndarray:
    prob_array = np.array(prob_list_val)  # (n_modelos, n_muestras, n_clases)
    best = {"score": -1, "weights": None}
    for w in itertools.product(w_range, repeat=prob_array.shape[0]):
        w = np.array(w, dtype=float)
        w = w / w.sum()
        proba = np.tensordot(prob_array, w, axes=((0,), (0,)))
        preds = np.argmax(proba, axis=1)
        score = f1_score(y_val, preds, average='weighted')
        if score > best['score']:
            best['score'] = score
            best['weights'] = w.copy()
    logger.info("Mejores pesos del ensamble encontrados (grid): %s -> f1=%.4f", best['weights'], best['score'])
    return best['weights']


def threshold_tuning(ensemble_proba: np.ndarray, y_true: np.ndarray) -> Dict:
    # Solo se implementó la afinación del umbral binario (extensión multiclase posible por clase)
    out = {"best_threshold": None, "best_f1": None}
    if ensemble_proba.shape[1] != 2:
        return out
    best_f1 = -1
    best_t = 0.5
    for t in np.linspace(0.3, 0.7, 41):
        preds = (ensemble_proba[:, 1] >= t).astype(int)
        score = f1_score(y_true, preds, average='weighted')
        if score > best_f1:
            best_f1 = score
            best_t = t
    out['best_threshold'] = float(best_t)
    out['best_f1'] = float(best_f1)
    logger.info("Resultado de ajuste del umbral: threshold=%.3f, f1=%.4f", best_t, best_f1)
    return out

